#!/usr/bin/env php
<?php

declare(strict_types=1);

(static function (): void {
    $candidates = [
        __DIR__ . '/../../../autoload.php',   // installed as a dependency
        __DIR__ . '/../vendor/autoload.php',  // running from package root
    ];

    foreach ($candidates as $file) {
        if (file_exists($file)) {
            require $file;

            return;
        }
    }

    fwrite(STDERR, "Could not locate autoload.php\n");
    exit(1);
})();

use Myerscode\Beacon\Driver\ChromeDriverInstaller;

$command = $argv[1] ?? 'install';

match ($command) {
    'install' => print(new ChromeDriverInstaller()->install()->output()),
    'update'  => print(new ChromeDriverInstaller()->update()->output()),
    'clean'   => print(new ChromeDriverInstaller()->clean()->output()),
    default   => (static function () use ($command): never {
        echo sprintf("Unknown command: %s\n", $command);
        echo "Usage: beacon-driver [install|update|clean]\n";
        exit(1);
    })(),
};
