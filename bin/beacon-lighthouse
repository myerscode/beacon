#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use Myerscode\Beacon\Support\LighthouseManager;

$command = $argv[1] ?? 'install';

match ($command) {
    'install' => print(LighthouseManager::install()->output()),
    'update'  => print(LighthouseManager::update()->output()),
    'remove'  => print(LighthouseManager::remove()->output()),
    default   => (static function () use ($command): never {
        echo sprintf("Unknown command: %s\n", $command);
        echo "Usage: beacon-lighthouse [install|update|remove]\n";
        exit(1);
    })(),
};
