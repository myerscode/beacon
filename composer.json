{
    "name": "myerscode/beacon",
    "description": "A fluent PHP wrapper for web page content retrieval, screenshots, PDFs, Lighthouse audits, and concurrent site crawling using Chrome.",
    "keywords": [
        "browser",
        "chrome",
        "crawler",
        "lighthouse",
        "panther",
        "pdf",
        "screenshot",
        "scraping",
        "seo",
        "spider",
        "web-scraping",
        "webdriver"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
          "name": "myerscode",
          "email": "team@myerscode.com",
          "homepage": "https://myerscode.com"
        },
        {
          "name": "Fred Myerscough",
          "email": "fred@myerscough.co.uk"
        }
      ],
    "require": {
        "php": "^8.5",
        "symfony/panther": "^2.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.29"
    },
    "bin": [
        "bin/beacon-driver",
        "bin/beacon-lighthouse"
    ],
    "autoload": {
        "psr-4": {
            "Myerscode\\Beacon\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Myerscode\\Beacon\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-install-cmd": [
            "@driver:install"
        ],
        "post-update-cmd": [
            "@driver:update"
        ],
        "driver:install":     "beacon-driver install",
        "driver:update":      "beacon-driver update",
        "driver:clean":       "beacon-driver clean",
        "lighthouse:install": "beacon-lighthouse install",
        "lighthouse:update":  "beacon-lighthouse update",
        "lighthouse:remove":  "beacon-lighthouse remove",
        "lint":               "vendor/bin/pint",
        "analyse":            "vendor/bin/phpstan analyse",
        "tests":              "vendor/bin/phpunit --testdox --no-coverage --colors=always",
        "test-coverage":      "vendor/bin/phpunit --testdox --colors=always",
        "security-audit":     "@composer audit"
    }
}
