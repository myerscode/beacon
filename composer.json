{
    "name": "myerscode/beacon",
    "description": "A fluent wrapper around Symfony Panther for easy browser interaction, screenshots, and rendered source retrieval.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fred Myerscough",
            "email": "fred@myerscode.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/panther": "^2.4",
        "dbrekelmans/bdi": "^1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Myerscode\\Beacon\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Myerscode\\Beacon\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-install-cmd": [
            "@install-drivers"
        ],
        "post-update-cmd": [
            "@install-drivers"
        ],
        "install-drivers": "bdi detect drivers",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse",
        "tests": "vendor/bin/phpunit --testdox --no-coverage --colors=always",
        "test-coverage": "vendor/bin/phpunit --testdox --colors=always",
        "security-audit": "@composer audit"
    }
}
